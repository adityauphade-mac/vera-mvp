# Local-only raw RoofLink export. Never used at build or runtime on
# Vercel — the dashboard reads from Postgres directly. Excluding it so
# `vercel --prod` doesn't upload the 196 MB file from a stray local copy.
data/jobs_dedup.jsonl
data/generated.json

# Build outputs
node_modules
.next
.turbo
dist
out

# Tests + dev artifacts. tests/fixtures/* (including the checked-in
# vera_test.sql seed and *.fixture.json files) are local-only — they
# never get bundled with the deployed app.
tests/e2e/audit-screens
tests/fixtures
playwright-report
test-results
coverage

# Production secrets recovery copy — never upload. See CLAUDE.md
# "Production environment" for the policy. The runtime reads its env
# from Vercel's runtime, not from this file.
.env.prod

# Misc
.DS_Store
*.log
.vercel
# Claude Code agent workdir — keeps the manual `vercel --prod` upload from
# trying to ship a worktree's copy of data/jobs_dedup.jsonl (would blow
# past Vercel's 100 MB upload limit).
.claude
# Git worktrees carry their own copies of the gitignored 196 MB JSONL.
# Same failure mode as .claude above — exclude from upload.
worktrees
