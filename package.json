{
  "name": "vera-mvp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:e2e": "./scripts/test-e2e.sh",
    "test:e2e:ui": "./scripts/test-e2e.sh --ui",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@vera/domain": "workspace:*",
    "@vera/types": "workspace:*"
  },
  "devDependencies": {
    "@auth/core": "0.41.2",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "pg": "^8.13.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,md,json}": "prettier --write"
  }
}
