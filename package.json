{
  "name": "vera-mvp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "preprocess": "tsx scripts/preprocess.ts",
    "dev": "turbo run dev",
    "build": "pnpm preprocess && turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:e2e": "pnpm preprocess && pnpm --filter @vera/web build && playwright test",
    "test:e2e:ui": "pnpm preprocess && pnpm --filter @vera/web build && playwright test --ui",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@vera/domain": "workspace:*",
    "@vera/types": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,md,json}": "prettier --write"
  }
}
