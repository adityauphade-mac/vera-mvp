# Required for /api/chat (OpenAI GPT-4o-mini via Vercel AI SDK)
OPENAI_API_KEY=

# Required for /api/brief/send (Resend). Without this set, the route returns 503.
# Dev sender is restricted to onboarding@resend.dev (sandbox — only sends to
# the Resend account holder's email). Set EMAIL_FROM once a domain is verified.
RESEND_API_KEY=
EMAIL_FROM="Vera <onboarding@resend.dev>"

# Cron triggers come from Upstash QStash. Grab both keys from the QStash
# dashboard under "Console → Details → Signing Keys" — they rotate
# independently so we have to know both. Without them set, the cron
# endpoints fall back to checking `Authorization: Bearer $CRON_SECRET`
# (used by manual `workflow_dispatch` runs).
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Legacy bearer auth for cron endpoints. Still accepted as a fallback so
# the manual `workflow_dispatch` button in GitHub Actions keeps working
# in an emergency.
CRON_SECRET=

# Optional: enable live AI in local Playwright runs
# RUN_LIVE_AI=1

# Optional: enable live Resend in local Playwright runs (will actually send email)
# RUN_LIVE_EMAIL=1
